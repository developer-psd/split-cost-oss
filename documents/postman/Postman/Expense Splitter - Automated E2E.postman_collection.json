        "exec": [
          "if (!pm.collectionVariables.get('run_id')) {",
          "  pm.collectionVariables.set('run_id', String(Date.now()));",
          "}",
          "var resolvedBaseUrl = pm.environment.get('baseUrl') || pm.collectionVariables.get('baseUrl') || pm.globals.get('baseUrl') || 'http://localhost:8080';",
          "pm.collectionVariables.set('baseUrl', resolvedBaseUrl);",
          "pm.environment.set('baseUrl', resolvedBaseUrl);"
        ]
      }
