                  "var data = pm.response.json();",
                  "pm.test('Trip contains four participants', function () { pm.expect(data.participants).to.have.length(4); });"
                ]
              }
            },
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "var participantFlowTripId = pm.collectionVariables.get('participant_flow_trip_id') || pm.environment.get('participant_flow_trip_id') || pm.globals.get('participant_flow_trip_id');",
                  "if (!participantFlowTripId) { throw new Error('participant_flow_trip_id is missing'); }",
                  "pm.collectionVariables.set('participant_flow_trip_id', participantFlowTripId);",
                  "pm.environment.set('participant_flow_trip_id', participantFlowTripId);",
                  "pm.globals.set('participant_flow_trip_id', participantFlowTripId);"
                ]
              }
            }
          ]
        },
        {
          "name": "Remove added participant",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": "{{baseUrl}}/trip/{{participant_flow_trip_id}}/participants",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"participants\": [\"{{participant_Kiran}}\"]\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200', function () { pm.response.to.have.status(200); });",
                  "var data = pm.response.json();",
                  "pm.test('Participant list is back to three', function () { pm.expect(data.participants).to.have.length(3); });",
                  "pm.test('Kiran is absent after deletion', function () {",
                  "  var stillThere = (data.participants || []).find(function (p) { return p.name === 'Kiran'; });",
                  "  pm.expect(stillThere).to.be.undefined;",
                  "});"
                ]
              }
