  "item": [
    {
      "name": "01 - Participant Management Flow",
      "description": "Covers create trip, add participant, remove participant, detail retrieval, and cleanup.",
      "item": [
        {
          "name": "Create participant-flow trip",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": "{{baseUrl}}/trip",
            "body": {
              "mode": "raw",
              "raw": "{{participantFlowCreateBody}}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          },
          "response": [],
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const body = {",
                  "  name: `Postman Participant Flow ${pm.collectionVariables.get('run_id')}`,",
                  "  participants: ['Hari', 'Uma', 'Tara']",
                  "};",
                  "pm.collectionVariables.set('participantFlowCreateBody', JSON.stringify(body, null, 2));"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200', function () { pm.response.to.have.status(200); });",
                  "var data = pm.response.json();",
                  "pm.test('Trip id is returned', function () { pm.expect(data.tripId).to.be.a('string').and.not.empty; });",
                  "pm.collectionVariables.set('participant_flow_trip_id', data.tripId);",
                  "pm.environment.set('participant_flow_trip_id', data.tripId);",
                  "pm.globals.set('participant_flow_trip_id', data.tripId);",
                  "pm.test('Three participants are returned', function () { pm.expect(data.participants).to.have.length(3); });"
                ]
              }
            }
          ]
        },
        {
          "name": "Add one participant",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": "{{baseUrl}}/trip/{{participant_flow_trip_id}}/participants",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"participants\": [\"Kiran\"]\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200', function () { pm.response.to.have.status(200); });",
                  "var data = pm.response.json();",
                  "pm.test('Participant list now has four entries', function () { pm.expect(data.participants).to.have.length(4); });",
                  "var added = (data.participants || []).find(function (p) { return p.name === 'Kiran'; });",
                  "pm.test('Added participant Kiran is present', function () { pm.expect(added).to.exist; pm.expect(added.participantId).to.be.a('string').and.not.empty; });",
                  "pm.collectionVariables.set('participant_Kiran', added.participantId);",
                  "pm.environment.set('participant_Kiran', added.participantId);",
                  "pm.globals.set('participant_Kiran', added.participantId);"
                ]
              }
            },
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "var participantFlowTripId = pm.collectionVariables.get('participant_flow_trip_id') || pm.environment.get('participant_flow_trip_id') || pm.globals.get('participant_flow_trip_id');",
                  "if (!participantFlowTripId) { throw new Error('participant_flow_trip_id is missing'); }",
                  "pm.collectionVariables.set('participant_flow_trip_id', participantFlowTripId);",
                  "pm.environment.set('participant_flow_trip_id', participantFlowTripId);",
                  "pm.globals.set('participant_flow_trip_id', participantFlowTripId);"
                ]
              }
