{
  "info": {
    "_postman_id": "f4ee46ea-4e32-4dd1-b629-f23f08eb0c42",
    "name": "Expense Splitter - Automated E2E",
    "description": "Automated Postman collection for the Expense Splitter API.\n\nThis collection is designed to run end-to-end against the current application, capture dynamic IDs,\nbuild transaction payloads from the created participants, execute both basic and simplified settlement flows,\nand clean up created data. It also includes participant-management flow coverage and negative validation checks.\n\nNotes:\n- The collection intentionally avoids the currently broken transaction query endpoints in the active flow.\n- A disabled folder named 'Known Current API Gaps' documents those requests for future enablement.\n- Use the supplied Newman scripts for fully automated execution and report generation.\n",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
