                  "var participantFlowTripId = pm.collectionVariables.get('participant_flow_trip_id') || pm.environment.get('participant_flow_trip_id') || pm.globals.get('participant_flow_trip_id');",
                  "if (!participantFlowTripId) { throw new Error('participant_flow_trip_id is missing'); }",
                  "pm.collectionVariables.set('participant_flow_trip_id', participantFlowTripId);",
                  "pm.environment.set('participant_flow_trip_id', participantFlowTripId);",
                  "pm.globals.set('participant_flow_trip_id', participantFlowTripId);",
                  "var participantKiran = pm.collectionVariables.get('participant_Kiran') || pm.environment.get('participant_Kiran') || pm.globals.get('participant_Kiran');",
                  "if (!participantKiran) { throw new Error('participant_Kiran is missing'); }",
                  "pm.collectionVariables.set('participant_Kiran', participantKiran);",
                  "pm.environment.set('participant_Kiran', participantKiran);",
                  "pm.globals.set('participant_Kiran', participantKiran);"
                ]
              }
            }
          ]
        },
        {
          "name": "Delete participant-flow trip",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": "{{baseUrl}}/trip/{{participant_flow_trip_id}}"
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200', function () { pm.response.to.have.status(200); });",
                  "var data = pm.response.json();",
                  "var tripId = pm.collectionVariables.get('participant_flow_trip_id') || pm.environment.get('participant_flow_trip_id') || pm.globals.get('participant_flow_trip_id');",
                  "pm.test('Deleted trip id is echoed back', function () { pm.expect(data.tripId).to.eql(tripId); });"
                ]
              }
            },
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "var participantFlowTripId = pm.collectionVariables.get('participant_flow_trip_id') || pm.environment.get('participant_flow_trip_id') || pm.globals.get('participant_flow_trip_id');",
                  "if (!participantFlowTripId) { throw new Error('participant_flow_trip_id is missing'); }",
                  "pm.collectionVariables.set('participant_flow_trip_id', participantFlowTripId);",
                  "pm.environment.set('participant_flow_trip_id', participantFlowTripId);",
                  "pm.globals.set('participant_flow_trip_id', participantFlowTripId);"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "02 - Settlement E2E Flow",
      "description": "Creates a trip, posts transactions dynamically using returned participant IDs, runs basic and simplified settlement, deletes one transaction, recomputes settlement, and cleans up.",
      "item": [
        {
          "name": "Create settlement-flow trip",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": "{{baseUrl}}/trip",
            "body": {
              "mode": "raw",
              "raw": "{{settlementFlowCreateBody}}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          },
          "response": [],
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const body = {",
                  "  name: `Postman Settlement Flow ${pm.collectionVariables.get('run_id')}`,",
                  "  participants: ['Alice', 'Bob', 'Smith', 'Wonder', 'Mat', 'Philips', 'Aleena', 'Kimberly']",
                  "};",
                  "pm.collectionVariables.set('settlementFlowCreateBody', JSON.stringify(body, null, 2));"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200', function () { pm.response.to.have.status(200); });",
                  "var data = pm.response.json();",
                  "pm.collectionVariables.set('trip_id', data.tripId);",
                  "pm.environment.set('trip_id', data.tripId);",
                  "pm.globals.set('trip_id', data.tripId);",
                  "pm.test('Eight participants are returned', function () { pm.expect(data.participants).to.have.length(8); });",
                  "var mapByName = {};",
                  "(data.participants || []).forEach(function (p) { mapByName[p.name] = p.participantId; });",
                  "['Alice','Bob','Smith','Wonder','Mat','Philips','Aleena','Kimberly'].forEach(function (name) {",
                  "  pm.collectionVariables.set('participant_' + name, mapByName[name]);",
                  "  pm.environment.set('participant_' + name, mapByName[name]);",
                  "  pm.globals.set('participant_' + name, mapByName[name]);",
                  "  pm.test('Participant id captured for ' + name, function () { pm.expect(mapByName[name]).to.be.a('string').and.not.empty; });",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Get settlement-flow trip details",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/trip/{{trip_id}}/details"
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200', function () { pm.response.to.have.status(200); });",
                  "var data = pm.response.json();",
                  "var tripId = pm.collectionVariables.get('trip_id') || pm.environment.get('trip_id') || pm.globals.get('trip_id');",
                  "pm.test('Trip id matches the created trip', function () { pm.expect(data.tripId).to.eql(tripId); });",
                  "pm.test('Trip contains eight participants', function () { pm.expect(data.participants).to.have.length(8); });"
                ]
              }
            },
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "var tripId = pm.collectionVariables.get('trip_id') || pm.environment.get('trip_id') || pm.globals.get('trip_id');",
                  "if (!tripId) { throw new Error('trip_id is missing'); }",
                  "pm.collectionVariables.set('trip_id', tripId);",
                  "pm.environment.set('trip_id', tripId);",
                  "pm.globals.set('trip_id', tripId);"
                ]
              }
            }
          ]
        },
        {
          "name": "Post dynamic transactions",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": "{{baseUrl}}/trip/{{trip_id}}/transactions",
            "body": {
              "mode": "raw",
              "raw": "{{transactionsBody}}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          },
          "response": [],
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "var tripId = pm.collectionVariables.get('trip_id') || pm.environment.get('trip_id') || pm.globals.get('trip_id');",
                  "if (!tripId) { throw new Error('trip_id is missing before posting transactions'); }",
                  "pm.collectionVariables.set('trip_id', tripId);",
                  "pm.environment.set('trip_id', tripId);",
                  "pm.globals.set('trip_id', tripId);",
                  "var pick = function (name) {",
                  "  return pm.collectionVariables.get('participant_' + name) || pm.environment.get('participant_' + name) || pm.globals.get('participant_' + name);",
                  "};",
                  "var requiredNames = ['Alice','Bob','Smith','Wonder','Mat','Philips','Aleena','Kimberly'];",
                  "var missing = requiredNames.filter(function (name) { return !pick(name); });",
                  "if (missing.length) { throw new Error('Missing participant ids for: ' + missing.join(', ')); }",
                  "var id = function (name) { return pick(name); };",
                  "var body = {",
                  "  transactions: [",
                  "    {",
                  "      spentAmount: 3030,",
                  "      spentBy: id('Bob'),",
                  "      spentOn: 'FOOD',",
                  "      spentDate: '01/01/2020',",
                  "      benefittedBy: [id('Alice'), id('Bob'), id('Smith'), id('Wonder'), id('Mat'), id('Philips'), id('Aleena'), id('Kimberly')]",
                  "    },",
                  "    {",
                  "      spentAmount: 1000,",
                  "      spentBy: id('Philips'),",
                  "      spentOn: 'TRANSPORT',",
                  "      spentDate: '01/01/2020',",
                  "      benefittedBy: [id('Alice'), id('Bob'), id('Smith'), id('Wonder'), id('Mat'), id('Philips'), id('Aleena'), id('Kimberly')]",
                  "    },",
                  "    {",
                  "      spentAmount: 100,",
                  "      spentBy: id('Kimberly'),",
                  "      spentOn: 'FOOD',",
                  "      spentDate: '01/01/2020',",
                  "      benefittedBy: [id('Wonder'), id('Mat'), id('Philips'), id('Aleena'), id('Kimberly')]",
                  "    },",
                  "    {",
                  "      spentAmount: 1100,",
                  "      spentBy: id('Kimberly'),",
                  "      spentOn: 'STAY',",
                  "      spentDate: '01/01/2020',",
                  "      benefittedBy: [id('Aleena'), id('Kimberly')]",
                  "    }",
                  "  ]",
                  "};",
                  "var bodyJson = JSON.stringify(body, null, 2);",
                  "pm.collectionVariables.set('transactionsBody', bodyJson);",
                  "pm.environment.set('transactionsBody', bodyJson);",
                  "pm.request.body.update(bodyJson);"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200', function () { pm.response.to.have.status(200); });",
                  "var data = [];",
                  "try { data = pm.response.json(); } catch (e) {}",
                  "if (pm.response.code !== 200) { console.log('Post dynamic transactions error payload:', data); }",
                  "pm.test('Four transactions are created', function () { pm.expect(data).to.be.an('array').with.length(4); });",
                  "if (Array.isArray(data) && data.length === 4) {",
                  "  ['1','2','3','4'].forEach(function (n, index) {",
                  "    var txId = data[index].transactionId;",
                  "    pm.collectionVariables.set('transaction_' + n + '_id', txId);",
                  "    pm.environment.set('transaction_' + n + '_id', txId);",
                  "    pm.globals.set('transaction_' + n + '_id', txId);",
                  "  });",
                  "}",
                  "pm.test('All transaction ids are captured', function () {",
                  "  ['1','2','3','4'].forEach(function (n) {",
                  "    var txId = pm.collectionVariables.get('transaction_' + n + '_id') || pm.environment.get('transaction_' + n + '_id') || pm.globals.get('transaction_' + n + '_id');",
                  "    pm.expect(txId, 'transaction_' + n + '_id').to.be.a('string').and.not.empty;",
                  "  });",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Compute basic settlement",
          "request": {
            "method": "POST",
            "header": [],
            "url": "{{baseUrl}}/trip/{{trip_id}}/settlement?simplify=false"
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200', function () { pm.response.to.have.status(200); });",
                  "var rawResponse = {};",
                  "try { rawResponse = pm.response.json(); } catch (e) {}",
                  "var responseJson = [];",
                  "if (Array.isArray(rawResponse)) {",
                  "  responseJson = rawResponse;",
                  "} else if (Array.isArray(rawResponse.settlement)) {",
                  "  responseJson = rawResponse.settlement;",
                  "} else if (Array.isArray(rawResponse.settlements)) {",
                  "  responseJson = rawResponse.settlements;",
                  "} else if (Array.isArray(rawResponse.currentSettlement)) {",
                  "  responseJson = rawResponse.currentSettlement;",
                  "}",
                  "pm.test('Settlement response is an array', function () { pm.expect(responseJson).to.be.an('array'); });",
                  "pm.test('Basic settlement is non-empty', function () { pm.expect(responseJson.length).to.be.greaterThan(0); });",
                  "responseJson.forEach((row, index) => {",
                  "  pm.test(`Basic settlement row ${index + 1} is well formed`, function () {",
                  "    pm.expect(row.from).to.be.a('string').and.not.empty;",
                  "    pm.expect(row.to).to.be.a('string').and.not.empty;",
                  "    pm.expect(Number(row.amount)).to.be.greaterThan(0);",
                  "  });",
                  "});",
                  "pm.collectionVariables.set('basic_settlement_count', String(responseJson.length));"
                ]
              }
            },
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "var tripId = pm.collectionVariables.get('trip_id') || pm.environment.get('trip_id') || pm.globals.get('trip_id');",
                  "if (!tripId) { throw new Error('trip_id is missing'); }",
                  "pm.collectionVariables.set('trip_id', tripId);",
                  "pm.environment.set('trip_id', tripId);",
                  "pm.globals.set('trip_id', tripId);"
                ]
              }
            }
          ]
        },
        {
          "name": "Compute simplified settlement",
          "request": {
            "method": "POST",
            "header": [],
            "url": "{{baseUrl}}/trip/{{trip_id}}/settlement?simplify=true"
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200', function () { pm.response.to.have.status(200); });",
                  "var rawResponse = {};",
                  "try { rawResponse = pm.response.json(); } catch (e) {}",
                  "var responseJson = [];",
                  "if (Array.isArray(rawResponse)) {",
                  "  responseJson = rawResponse;",
                  "} else if (Array.isArray(rawResponse.settlement)) {",
                  "  responseJson = rawResponse.settlement;",
                  "} else if (Array.isArray(rawResponse.settlements)) {",
                  "  responseJson = rawResponse.settlements;",
                  "} else if (Array.isArray(rawResponse.currentSettlement)) {",
                  "  responseJson = rawResponse.currentSettlement;",
                  "}",
                  "var basicCount = Number(pm.collectionVariables.get('basic_settlement_count') || '0');",
                  "pm.test('Settlement response is an array', function () { pm.expect(responseJson).to.be.an('array'); });",
                  "pm.test('Simplified settlement is non-empty', function () { pm.expect(responseJson.length).to.be.greaterThan(0); });",
                  "pm.test('Simplified settlement is not longer than the basic settlement', function () { pm.expect(responseJson.length).to.be.at.most(basicCount); });"
                ]
              }
            },
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
